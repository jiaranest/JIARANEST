{
  "name": "zylo-testing-app",
  "version": "0.0.7",
  "scripts": {
    "ng": "ng",
    "gen:version": "node scripts/gen-version.mjs",
    "prestart": "node scripts/gen-version.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "bump": "npm version patch --no-git-tag-version --allow-same-version && node scripts/gen-version.mjs",
    "build:gh": "ng build --base-href \"/JIARANEST/\"",
    "copy:404": "node -e \"require('fs').copyFileSync('dist/Zylo_testing_app/browser/index.html','dist/Zylo_testing_app/browser/404.html')\"",
    "publish:gh": "npx --yes angular-cli-ghpages --dir=dist/Zylo_testing_app/browser",
    "deploy": "npm run bump && npm run build:gh && npm run copy:404 && npm run publish:gh",
    "release": "npm version patch --no-git-tag-version && node scripts/gen-version.mjs"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.4",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
