{
  "name": "jiaranest-server",
  "version": "0.1.0",
  "description": "Jiaranest catalog API (Phase 2a) — NestJS + Prisma + PostgreSQL",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node --project prisma/tsconfig.seed.json prisma/seed.ts",
    "seed:force": "ts-node --project prisma/tsconfig.seed.json prisma/seed.ts --force",
    "gen:seed": "ts-node --project prisma/tsconfig.seed.json prisma/gen-seed-data.ts",
    "db:reset": "prisma migrate reset --force",
    "render:build": "npm install && prisma generate && nest build",
    "render:start": "prisma db push --skip-generate && npm run seed && node dist/main.js"
  },
  "prisma": {
    "seed": "ts-node --project prisma/tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.19.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^6.9.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "prisma": "^5.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^6.4.16"
  }
}
